# Personal Dash Agent Configuration
# Copy this to agent.env and fill in your values.

# Required: Backend API URL
DASH_API_URL=https://dash.example.com/api/v1

# Required: API key from the dashboard (generated when registering a server)
DASH_API_KEY=your-api-key-here

# Required: Server ID assigned by the dashboard
DASH_SERVER_ID=1

# Optional: Seconds between metric collection (default: 60, minimum: 10)
DASH_POLL_INTERVAL=60

# Optional: Collect Docker container stats (default: true)
DASH_COLLECT_DOCKER=true

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
DASH_LOG_LEVEL=INFO
