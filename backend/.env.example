DATABASE_URL=mysql+pymysql://user:password@localhost:3306/personal_dash
SECRET_KEY=your-secret-key-here-change-in-production

# CORS Configuration
# For development (allow all origins):
# CORS_ORIGINS=["*"]
#
# For production (specific origins only):
# CORS_ORIGINS=["https://dash.yourdomain.com"]
#
# For multiple origins (local + network):
# CORS_ORIGINS=["http://localhost:5173","http://192.168.1.100:5173"]
#
# Default allows all origins for easier development
CORS_ORIGINS=["*"]
